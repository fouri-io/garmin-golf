# Copy to .env (which is gitignored) and fill in.
# Or leave blank and the scripts will prompt interactively via getpass.
GARMIN_EMAIL=
GARMIN_PASSWORD=

# Optional: where the garminconnect library caches its token store.
# Defaults to ~/.garminconnect/ if unset.
# GARMINTOKENS=~/.garminconnect

# AI coach (optional). Without a key, the coach step is skipped gracefully.
ANTHROPIC_API_KEY=
# Override the model if needed (default: claude-sonnet-4-5)
# CLAUDE_MODEL=claude-sonnet-4-5
