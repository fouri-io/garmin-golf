# Copy to .env (which is gitignored) and fill in.
# Or leave blank and the scripts will prompt interactively via getpass.
GARMIN_EMAIL=
GARMIN_PASSWORD=

# Optional: where the garminconnect library caches its token store.
# Defaults to ~/.garminconnect/ if unset.
# GARMINTOKENS=~/.garminconnect

# AI coach (optional). Set EITHER key — the provider is auto-selected.
# Anthropic (Claude): key starts sk-ant-…   OpenAI (GPT): key starts sk-…
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Override the model if needed (defaults: claude-sonnet-4-5 / gpt-4o)
# CLAUDE_MODEL=claude-sonnet-4-5
# OPENAI_MODEL=gpt-4o
